# ─────────────────────────────────────────────
# WealthArc Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# Admin panel password (change this!)
ADMIN_PASSWORD=wealtharc_admin_2026

# Secret key for admin session token (any long random string)
ADMIN_SECRET=replace_with_a_long_random_secret_string

# CORS — set to your Lovable frontend URL
ALLOWED_ORIGIN=https://investpath-rise.lovable.app

# ─── Email notifications (Nodemailer) ───────
# Use Gmail App Password or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Where new lead notifications are sent (your inbox)
NOTIFY_EMAIL=hello@wealtharc.in

# Sender name shown in emails
FROM_NAME=WealthArc Website
FROM_EMAIL=your_gmail@gmail.com
